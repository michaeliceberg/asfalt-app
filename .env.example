# Шаблон переменных окружения.
# Скопируй в .env.local (для разработки) или .env.production (на сервере)
# и заполни реальными значениями. Эти файлы НЕ коммитятся в git.

# --- UNF (1С / Rarus) ---
UNF_LOGIN=
UNF_PASSWORD=
UNF_BASE_URL=

# --- Cron / внутренние вызовы ---
# Длинная случайная строка, ей защищены /api/cron-* эндпоинты
CRON_SECRET=

# --- Авторизация ---
# ВАЖНО: если не задать, в коде используется значение по умолчанию
# 'your-secret-key' — оно прямо в открытом виде лежит в публичном репозитории,
# так что без реального JWT_SECRET токены можно подделать. Сгенерировать: openssl rand -hex 32
JWT_SECRET=

# --- База данных ---
# Локально и на сервере путь одинаковый, но файлы разные (это просто локальный SQLite-файл)
DATABASE_URL=file:./data/sqlite.db

# --- Telegram-бот ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# --- Синхронизация ---
SYNC_ALERT_MINUTES=25

# --- Яндекс.Карты ---
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# --- Web Push (VAPID) ---
# Сгенерировать: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com
